  <!-- RESEARCH -->
  <section id="research" class="py-20 px-6 border-t border-[#21262d]">
    <div class="max-w-5xl mx-auto">
      <h2 class="section-heading">Research</h2>
      <p class="text-[#8b949e] mb-10 max-w-2xl leading-relaxed">
        My research sits at the intersection of computational methods and behavioral science —
        building scalable systems that extract and interpret meaningful signals from human movement
        and physiology.
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Pillar 1 -->
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-sky-400/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Behavioral Phenotyping</h3>
          <p class="text-[#8b949e] text-sm leading-relaxed">
            KineSig: kinematic movement signatures from pose data (108 actors, 12 emotions)
            linked to autism-relevant psychometric scores (AQ, RMET, TIPI) via GNNs and DTW clustering.
          </p>
          <div class="mt-3 flex flex-wrap gap-1">
            <span class="tag">GNN</span><span class="tag">DTW</span><span class="tag">Autism/RDoC</span>
