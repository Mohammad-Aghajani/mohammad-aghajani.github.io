  <!-- PROJECTS -->
  <section id="projects" class="py-20 px-6 border-t border-[#21262d]">
    <div class="max-w-5xl mx-auto">
      <h2 class="section-heading">Projects</h2>

      <div class="grid md:grid-cols-2 gap-6">

        <!-- KineSig -->
        <div class="card group">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-semibold text-white text-lg">KineSig</h3>
            <span class="text-xs text-sky-400 font-medium">2021–present</span>
          </div>
          <p class="text-[#8b949e] text-sm leading-relaxed mb-4">
            End-to-end pipeline for behavioral phenotyping from human motion. Processes ~1.6M frames
            of pose data; computes velocity/acceleration time series, pairwise distance matrices
            (DTW, Soft-DTW, Euclidean, Cosine), and clusters participants. Includes a
            <strong class="text-[#c9d1d9]">Streamlit interactive dashboard</strong> for exploration.
            UIST 2026 submission under review.
          </p>
          <div class="flex flex-wrap gap-1">
            <span class="tag">Python</span><span class="tag">PyTorch</span><span class="tag">DTW</span>
            <span class="tag">GNN</span><span class="tag">Streamlit</span><span class="tag">R / lme4</span>
          </div>
        </div>

        <!-- OTIMS -->
        <div class="card">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-semibold text-white text-lg">OTIMS</h3>
            <span class="text-xs text-sky-400 font-medium">2024–present</span>
          </div>
          <p class="text-[#8b949e] text-sm leading-relaxed mb-4">
            Full-stack web platform for remote behavioral research. Participants record
            via webcam; platform runs automated landmark extraction (MediaPipe face mesh,
            OpenFace, DeepFace) and behavioral protocols. Deployed with Nginx + Gunicorn
            in production. Built with IU Seed Grant funding.
          </p>
          <div class="flex flex-wrap gap-1">
            <span class="tag">Flask</span><span class="tag">SQLite</span><span class="tag">MediaPipe</span>
            <span class="tag">OpenFace</span><span class="tag">Nginx</span>
          </div>
        </div>

        <!-- Game of Tell -->
        <div class="card">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-semibold text-white text-lg">Game of Tell</h3>
            <span class="text-xs text-sky-400 font-medium">2021–present</span>
          </div>
          <p class="text-[#8b949e] text-sm leading-relaxed mb-4">
            IRB-approved deception study using a two-player PsychoPy card game. Captures
            synchronized face video and remote PPG for 42+ subjects. Analyzes facial AUs,
            head pose, gaze, and inter-player physiological synchrony on Lie vs. Truth trials.
          </p>
          <div class="flex flex-wrap gap-1">
            <span class="tag">PsychoPy</span><span class="tag">OpenFace</span><span class="tag">rPPG</span>
            <span class="tag">Cross-correlation</span>
          </div>
        </div>

        <!-- BRiscOS -->
        <div class="card">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-semibold text-white text-lg">BRiscOS</h3>
            <span class="text-xs text-sky-400 font-medium">2025–present</span>
          </div>
          <p class="text-[#8b949e] text-sm leading-relaxed mb-4">
            Educational RISC-V microkernel OS in C and assembly, targeting QEMU. Built as
            teaching infrastructure for the OS course at IU. Subsystems: UART drivers,
            interrupt handling, round-robin/priority scheduler, futex, malloc with coalescing,
            ramdisk filesystem.
          </p>
          <div class="flex flex-wrap gap-1">
            <span class="tag">C</span><span class="tag">RISC-V</span><span class="tag">QEMU</span>
            <span class="tag">Systems</span>
          </div>
        </div>

      </div>
    </div>
